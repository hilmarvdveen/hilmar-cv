# Microsoft Graph (application / client-credentials flow) — required for the
# contact, cv-download and booking API routes.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
# Mailbox the app sends mail as and creates calendar events on.
SMTP_USER=hilmar@hilmarvanderveen.com

# Canonical site origin (no trailing slash). Used by robots.txt, the sitemap,
# and the SEO layer. Falls back to https://www.hilmarvanderveen.com when unset.
NEXT_PUBLIC_SITE_URL=https://www.hilmarvanderveen.com

# Analytics (optional; only loaded in production when set).
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# Google Search Console verification token (used by the layout + SEO metadata).
GOOGLE_SITE_VERIFICATION=
